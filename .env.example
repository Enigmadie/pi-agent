TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

AGENT_DB_PATH=./data/agent.db
AGENT_MEMORY_DIR=./memory

# Optional: path visible from the machine where pi-agent runs.
# On a Pi this should be a synced/copy of notes, not a Mac-local path.
OBSIDIAN_VAULT_PATH=/home/pi-agent/notes/obsidian-vault
PI5_NOTES_PATH=/home/pi-agent/notes/obsidian-vault/Projects/Pi 5 infrastructure

EDGE_HOST=192.168.1.10
CORE_HOST=192.168.1.20
IOT_HUB_HOST=192.168.1.20
EDGE_SSH_TARGET=edge-user@edge-host
EDGE_INFRA_PATH=/home/edge-user/infra
SYSTEMD_ALLOWED_SERVICES=docker,containerd
